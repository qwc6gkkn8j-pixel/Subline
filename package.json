{
  "name": "subline",
  "version": "1.0.0",
  "private": true,
  "description": "SUBLINE — Barbershop management system (monorepo)",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:server dev:client",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "db:push": "npm --workspace server run db:push",
    "db:migrate": "npm --workspace server run db:migrate",
    "db:seed": "npm --workspace server run db:seed",
    "db:generate": "npm --workspace server run db:generate"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  }
}
