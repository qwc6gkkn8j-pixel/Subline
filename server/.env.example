# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/subline?schema=public"

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:5173"
APP_URL="http://localhost:5173"

# Bcrypt
BCRYPT_ROUNDS=10

# Initial admin (created by db:seed)
ADMIN_EMAIL="admin@subline.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"

# ─── Stripe Connect (OPTIONAL — leave empty until your Stripe account is ready)
# Without these, payment-related routes return 503 "Stripe not configured".
# When you have your account:
#   1. Get keys at https://dashboard.stripe.com/test/apikeys
#   2. For Connect, register your platform at https://dashboard.stripe.com/settings/connect
#   3. Set the webhook secret from https://dashboard.stripe.com/test/webhooks
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_CLIENT_ID="ca_..."  # Connect platform client_id (for OAuth)
