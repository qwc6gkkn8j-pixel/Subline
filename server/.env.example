# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/subline?schema=public"

# JWT secrets (use long random strings in production)
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars-long"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars-long"
JWT_ACCESS_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=4000
CORS_ORIGIN="http://localhost:5173"

# Bcrypt
BCRYPT_ROUNDS=10

# Initial admin (created by db:seed)
ADMIN_EMAIL="admin@subline.local"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_NAME="Admin"
