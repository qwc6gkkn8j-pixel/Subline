// Prisma schema for SUBLINE — v3 (Stripe Connect)
// Run: npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ────────────────────────────────────────────────────────────────────────────
// ENUMS
// ────────────────────────────────────────────────────────────────────────────

enum Role {
  admin
  barber
  client
  staff
}

// StaffMember.TimeEntry — clock-in / break / clock-out events.
enum EntryType {
  clock_in
  break_start
  break_end
  clock_out
}

enum UserStatus {
  active
  inactive
}

// Legacy — kept for backwards compatibility with v1 subscriptions.
// New flow uses Plan FK on Subscription. Don't add to PlanType going forward.
enum PlanType {
  bronze
  silver
  gold
}

enum SubscriptionStatus {
  active
  inactive
  pending
  cancelled
  payment_failed
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum AppointmentService {
  haircut
  beard
  haircut_beard
  other
}

enum AppointmentStatus {
  pending
  confirmed
  cancelled
  completed
  no_show
}

enum CancelledBy {
  barber
  client
}

enum ConversationType {
  barber_client
  support
}

enum MessageType {
  text
  image
  system
}

enum TicketCategory {
  payment
  account
  booking
  other
}

enum TicketPriority {
  low
  medium
  high
}

enum TicketStatus {
  open
  in_progress
  resolved
  closed
}

enum OrderStatus {
  pending
  completed
  cancelled
}

// Pro status in the platform (managed by admin).
enum ProStatus {
  pending_onboarding  // registered but Stripe Connect not completed
  active              // fully onboarded
  suspended           // suspended by admin
}

// Automatic client segment calculated from visit frequency.
enum ClientSegment {
  vip        // active subscription + ≥3 visits in last 30 days
  mensal     // active subscription + 1-2 visits in last 30 days
  ocasional  // some activity but no active subscription
  inativo    // no appointment in last 60 days
}

// ────────────────────────────────────────────────────────────────────────────
// CORE — User / Barber / Client (v1 + Stripe additions)
// ────────────────────────────────────────────────────────────────────────────

model User {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  role         Role
  status       UserStatus @default(active)
  fullName     String
  phone        String?
  avatarUrl    String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  barber               Barber?
  client               Client?
  staffMember          StaffMember?
  auditLogs            AuditLog[]
  sentMessages         Message[]      @relation("MessageSender")
  notifications        Notification[]
  ticketsRequested     SupportTicket[] @relation("TicketRequester")
  conversationsAsAdmin Conversation[]  @relation("ConversationAdmin")
  favorites            Favorite[]

  @@index([email])
  @@index([role])
}

model Barber {
  id        String   @id @default(uuid())
  userId    String   @unique
  name      String
  phone     String?
  address   String?
  bio       String?
  rating    Decimal  @default(0) @db.Decimal(2, 1)
  // Stripe Connect — populated when barber connects their account via OAuth.
  stripeAccountId  String?
  stripeConnected  Boolean  @default(false)
  // Pro platform status (managed by admin).
  proStatus        ProStatus @default(active)
  // Discovery — professional categories and location.
  categories       String[]
  city             String?
  country          String   @default("LU")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  clients        Client[]
  plans          Plan[]
  appointments   Appointment[]
  availability   BarberAvailability[]
  unavailable    BarberUnavailable[]
  conversations  Conversation[]        @relation("ConversationBarber")
  staff          StaffMember[]
  services       Service[]
  products       Product[]
  productOrders  ProductOrder[]
  reviews        Review[]
  favorites      Favorite[]
}

model Client {
  id        String   @id @default(uuid())
  userId    String   @unique
  barberId  String?
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Calculated segment — refreshed on appointment completion.
  segment          ClientSegment?
  segmentUpdatedAt DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber        Barber?        @relation(fields: [barberId], references: [id], onDelete: SetNull)
  subscriptions Subscription[]
  appointments  Appointment[]
  conversations Conversation[] @relation("ConversationClient")
  productOrders ProductOrder[]
  reviews       Review[]

  @@index([barberId])
}

// ────────────────────────────────────────────────────────────────────────────
// PLANS & SUBSCRIPTIONS (v3 — dynamic plans per barber, Stripe-aware)
// ────────────────────────────────────────────────────────────────────────────

model Plan {
  id           String   @id @default(uuid())
  barberId     String
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  // null = unlimited cuts; otherwise the monthly allowance.
  cutsPerMonth Int?
  isActive     Boolean  @default(true)
  // Stripe — populated once the plan is synced to the barber's connected account.
  stripeProductId    String?
  stripePriceId      String?
  stripePaymentLink  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  barber        Barber         @relation(fields: [barberId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]

  @@index([barberId])
  @@index([isActive])
}

model Subscription {
  id          String             @id @default(uuid())
  clientId    String
  // v3: planId is the canonical reference. planType + price kept for v1 compat.
  planId      String?
  planType    PlanType?
  status      SubscriptionStatus @default(active)
  startDate   DateTime           @default(now())
  renewalDate DateTime
  price       Decimal            @db.Decimal(10, 2)
  // Cut tracking
  cutsUsed   Int @default(0)
  cutsTotal  Int @default(0)
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  // Stripe references
  stripeSubscriptionId String?
  stripeCustomerId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan     Plan?     @relation(fields: [planId], references: [id], onDelete: SetNull)
  payments Payment[]
  cuts     Cut[]

  @@index([clientId])
  @@index([planId])
  @@index([status])
}

model Payment {
  id             String        @id @default(uuid())
  subscriptionId String
  amount         Decimal       @db.Decimal(10, 2)
  status         PaymentStatus @default(paid)
  // Free-form payment method label as reported by Stripe (e.g. "card", "sepa_debit", "ideal")
  method         String?
  paymentDate    DateTime      @default(now())
  // Stripe references
  stripePaymentIntentId String?
  stripeInvoiceId       String?
  createdAt      DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([paymentDate])
  @@index([stripePaymentIntentId])
}

// ────────────────────────────────────────────────────────────────────────────
// CUT TRACKING (history of haircuts performed)
// ────────────────────────────────────────────────────────────────────────────

model Cut {
  id             String   @id @default(uuid())
  subscriptionId String
  appointmentId  String?  @unique
  performedAt    DateTime @default(now())
  notes          String?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  appointment  Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([subscriptionId])
  @@index([performedAt])
}

// ────────────────────────────────────────────────────────────────────────────
// CALENDAR — Appointments + Availability
// ────────────────────────────────────────────────────────────────────────────

model Appointment {
  id              String             @id @default(uuid())
  barberId        String
  clientId        String
  // Optional staff member assigned to this appointment (if null, it's the barber's)
  staffMemberId   String?
  // Legacy enum service (kept for back-compat with existing appointments).
  // New flow uses serviceId + priceAtBooking when the barber has a Service catalog.
  service         AppointmentService @default(haircut)
  serviceId       String?
  priceAtBooking  Decimal?           @db.Decimal(10, 2)
  date            DateTime           @db.Date
  startTime       String // "HH:MM" 24h
  endTime         String // "HH:MM" 24h
  durationMinutes Int                @default(30)
  status          AppointmentStatus  @default(pending)
  notes           String?
  clientNotes     String?
  cancelledBy     CancelledBy?
  cancelledAt     DateTime?
  reminderSentAt  DateTime?          // Track when appointment reminder notification was sent
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  barber        Barber         @relation(fields: [barberId], references: [id], onDelete: Cascade)
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staffMember   StaffMember?   @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  serviceRef    Service?       @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  cut           Cut?
  review        Review?

  @@index([barberId, date])
  @@index([clientId])
  @@index([staffMemberId])
  @@index([status])
  @@index([serviceId])
}

// ────────────────────────────────────────────────────────────────────────────
// REVIEWS — Client feedback for appointments
// ────────────────────────────────────────────────────────────────────────────

model Review {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  clientId      String
  barberId      String
  rating        Int      // 1-5 stars
  comment       String?  @db.Text
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  client      Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  barber      Barber      @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId])
  @@index([clientId])
  @@index([rating])
}

model BarberAvailability {
  id            String   @id @default(uuid())
  barberId      String
  // Optional staff member — if set, this is the staff member's availability, not the barber's
  staffMemberId String?
  dayOfWeek     Int // 0 = Sunday, 6 = Saturday
  startTime     String // "HH:MM"
  endTime       String // "HH:MM"
  slotDuration  Int      @default(30) // minutes — kept for backward compat (clients now infer slot length from service durations)
  // Optional mid-day break. When both are set, the slot algorithm
  // skips any slot that overlaps [breakStart, breakEnd).
  breakStart    String? // "HH:MM"
  breakEnd      String? // "HH:MM"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  barber       Barber        @relation(fields: [barberId], references: [id], onDelete: Cascade)
  staffMember  StaffMember?  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([barberId, dayOfWeek])
  @@index([staffMemberId])
}

model BarberUnavailable {
  id        String   @id @default(uuid())
  barberId  String
  dateFrom  DateTime @db.Date
  dateTo    DateTime @db.Date
  reason    String?
  createdAt DateTime @default(now())

  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@index([barberId, dateFrom])
}

// ────────────────────────────────────────────────────────────────────────────
// CHAT — Conversations + Messages + Support Tickets
// ────────────────────────────────────────────────────────────────────────────

model Conversation {
  id        String           @id @default(uuid())
  type      ConversationType
  // For type=barber_client: barberId + clientId set, adminId null
  // For type=support:        requester (barber or client) + adminId
  barberId  String?
  clientId  String?
  adminId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  barber  Barber?         @relation("ConversationBarber", fields: [barberId], references: [id], onDelete: Cascade)
  client  Client?         @relation("ConversationClient", fields: [clientId], references: [id], onDelete: Cascade)
  admin   User?           @relation("ConversationAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  messages Message[]
  ticket   SupportTicket?

  @@index([barberId])
  @@index([clientId])
  @@index([adminId])
}

model Message {
  id             String      @id @default(uuid())
  conversationId String
  senderId       String
  senderRole     Role
  content        String
  type           MessageType @default(text)
  imageUrl       String?
  isRead         Boolean     @default(false)
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
}

model SupportTicket {
  id             String         @id @default(uuid())
  requesterId    String
  requesterRole  Role
  conversationId String         @unique
  subject        String
  category       TicketCategory @default(other)
  priority       TicketPriority @default(medium)
  status         TicketStatus   @default(open)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  resolvedAt     DateTime?

  requester    User         @relation("TicketRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([requesterId])
  @@index([status])
  @@index([priority])
}

// ────────────────────────────────────────────────────────────────────────────
// NOTIFICATIONS
// ────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String // e.g. "payment_success", "appointment_reminder"
  title     String
  body      String
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ────────────────────────────────────────────────────────────────────────────
// SERVICES — barber's one-time service catalog (used by appointments)
// ────────────────────────────────────────────────────────────────────────────

model Service {
  id              String   @id @default(uuid())
  barberId        String
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  durationMinutes Int      @default(30)
  // Free-form bucket for UI grouping/filtering: Corte, Barba, Tratamento, Combo, Outro.
  category        String?
  isActive        Boolean  @default(true)
  // Optional photo url (asset upload is out of scope for this version).
  imageUrl        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barber       Barber        @relation(fields: [barberId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([barberId, isActive])
}

// ────────────────────────────────────────────────────────────────────────────
// STAFF — barber's employees + clock-in/out tracking
// ────────────────────────────────────────────────────────────────────────────

model StaffMember {
  id        String   @id @default(uuid())
  barberId  String
  // Optional User account — set when the staff member can sign in to the
  // /staff/badge page. Null when the barber tracks them without a login.
  userId    String?  @unique
  name      String
  // Free-form label: "Barbeiro", "Aprendiz", "Rececionista", etc.
  role      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  barber           Barber                  @relation(fields: [barberId], references: [id], onDelete: Cascade)
  user             User?                   @relation(fields: [userId], references: [id], onDelete: SetNull)
  entries          TimeEntry[]
  availabilities   BarberAvailability[]
  appointments     Appointment[]

  @@index([barberId])
  @@index([isActive])
}

model TimeEntry {
  id            String    @id @default(uuid())
  staffMemberId String
  type          EntryType
  timestamp     DateTime  @default(now())
  note          String?

  staffMember StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  @@index([staffMemberId, timestamp])
}

// ────────────────────────────────────────────────────────────────────────────
// SHOP — Products for sale by professionals
// ────────────────────────────────────────────────────────────────────────────

model Product {
  id              String   @id @default(uuid())
  barberId        String
  name            String
  description     String?
  price           Decimal  @db.Decimal(10, 2)
  // Type: "physical" (merchandise) or "digital" (e-book, course, etc.)
  type            String   @default("physical") // "physical" | "digital"
  imageUrl        String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  barber  Barber         @relation(fields: [barberId], references: [id], onDelete: Cascade)
  orders  ProductOrder[]

  @@index([barberId, isActive])
}

model ProductOrder {
  id        String      @id @default(uuid())
  barberId  String
  clientId  String
  productId String
  quantity  Int         @default(1)
  totalPrice Decimal    @db.Decimal(10, 2)
  status    OrderStatus @default(pending)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  barber    Barber   @relation(fields: [barberId], references: [id], onDelete: Cascade)
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([barberId])
  @@index([clientId])
  @@index([productId])
  @@index([status])
}

// ────────────────────────────────────────────────────────────────────────────
// FAVOURITES — clients saving pros for quick rebooking
// ────────────────────────────────────────────────────────────────────────────

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  barberId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  barber Barber @relation(fields: [barberId], references: [id], onDelete: Cascade)

  @@unique([userId, barberId])
  @@index([userId])
  @@index([barberId])
}

// ────────────────────────────────────────────────────────────────────────────
// AUDIT LOG (existing)
// ────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  userId     String
  action     String
  entityType String
  entityId   String
  details    Json?
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entityType])
  @@index([createdAt])
}
